# Keep the build context small and the image free of host-specific state.

.git
.github
.venv
venv
env
__pycache__
*.py[cod]
.pytest_cache

# Private working notes (gitignored, and not needed in the image).
NOTES.md

# Intermediate corpus artifacts: the shipped Qdrant collection is what the
# app reads at runtime. These are only needed to REBUILD it.
data/raw
data/interim
data/embeddings.npy

# Runtime lock, not state.
qdrant_data/.lock

# Evaluation harness: offline analysis, not part of the served application.
eval

# Local tooling
tests
*.md
!README.md
